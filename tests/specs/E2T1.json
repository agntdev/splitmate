[
  {
    "name": "/save stores a named expense",
    "steps": [
      {
        "send": { "text": "/save lunch 150" },
        "expect": [
          { "method": "sendMessage" }
        ]
      }
    ]
  },
  {
    "name": "/save without arguments shows usage",
    "steps": [
      {
        "send": { "text": "/save" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /save <name> <amount>\nExample: /save lunch 150" } }
        ]
      }
    ]
  },
  {
    "name": "/save with only name shows error",
    "steps": [
      {
        "send": { "text": "/save lunch" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Please provide both a name and an amount.\nUsage: /save <name> <amount>\nExample: /save lunch 150" } }
        ]
      }
    ]
  },
  {
    "name": "/save with invalid amount shows error",
    "steps": [
      {
        "send": { "text": "/save lunch abc" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Amount must be a positive number.\nExample: /save lunch 150" } }
        ]
      }
    ]
  },
  {
    "name": "/save with negative amount shows error",
    "steps": [
      {
        "send": { "text": "/save lunch -50" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Amount must be a positive number.\nExample: /save lunch 150" } }
        ]
      }
    ]
  }
]

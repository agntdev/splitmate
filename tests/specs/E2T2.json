[
  {
    "name": "/list with no expenses shows empty message",
    "steps": [
      {
        "send": { "text": "/list" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "No expenses saved yet." } }
        ]
      }
    ]
  },
  {
    "name": "/list shows saved expenses with timestamps",
    "steps": [
      {
        "send": { "text": "/save lunch 150" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/list" },
        "expect": [
          { "method": "sendMessage" }
        ]
      }
    ]
  }
]